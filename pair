<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>페어 매거진 — 서사틀</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;0,9..144,900;1,9..144,500&family=Noto+Serif+KR:wght@500;700;900&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#15140F;
  --paper:#FFFFFF;
  --paper-soft:#F6F5F1;
  --line:#E3E1D9;
  --accent:#D7263D;
  --accent-deep:#A31728;
  --gold:#B8985A;
  --muted:#8C8579;
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  background:#EDEBE4;
  font-family:'Noto Sans KR',sans-serif;
  color:var(--ink);
  -webkit-font-smoothing:antialiased;
}
.eyebrow{
  font-family:'Fraunces',serif;font-style:italic;font-weight:500;
  letter-spacing:.08em;text-transform:uppercase;
}

/* ===== toolbar ===== */
.toolbar{
  position:sticky;top:0;z-index:50;
  display:flex;align-items:center;justify-content:center;gap:14px;
  padding:14px 18px;background:var(--ink);color:var(--paper);flex-wrap:wrap;
}
.toolbar .brandmark{
  font-family:'Fraunces',serif;font-weight:600;font-size:14px;letter-spacing:.03em;
  margin-right:auto;color:var(--paper);opacity:.55;white-space:nowrap;
}
.toolbar button{
  font-family:'Noto Sans KR',sans-serif;font-size:13px;font-weight:500;
  background:transparent;color:var(--paper);border:1px solid rgba(255,255,255,.22);
  padding:8px 14px;border-radius:20px;cursor:pointer;transition:.15s;white-space:nowrap;
}
.toolbar button:hover{background:rgba(255,255,255,.1);border-color:var(--accent);}
.toolbar .dots{display:flex;gap:7px;align-items:center;}
.toolbar .dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.28);cursor:pointer;transition:.15s;}
.toolbar .dot.active{background:var(--accent);width:20px;border-radius:5px;}
.toolbar .save-btn{background:var(--accent);border-color:var(--accent);color:#fff;font-weight:700;}
.toolbar .save-btn:hover{background:var(--accent-deep);}
.help-strip{text-align:center;font-size:12px;color:var(--muted);padding:9px 12px;background:#DFDCD1;letter-spacing:.02em;}
.help-strip b{color:var(--accent-deep);}

/* ===== stage ===== */
.stage{padding:38px 16px 70px;display:flex;justify-content:center;}
.spread{display:none;gap:0;width:100%;max-width:1360px;filter:drop-shadow(0 26px 54px rgba(0,0,0,.16));}
.spread.active{display:flex;}
.page{
  position:relative;flex:1 1 0;aspect-ratio:3/4;background:var(--paper);
  padding:clamp(20px,3.6vw,46px) clamp(20px,3.4vw,44px);
  display:flex;flex-direction:column;overflow:hidden;
}
.page.left{border-radius:6px 0 0 6px;}
.page.right{border-radius:0 6px 6px 0;}
.gutter{width:14px;flex:0 0 14px;background:linear-gradient(90deg, rgba(0,0,0,.10), rgba(0,0,0,.015) 30%, rgba(0,0,0,.015) 70%, rgba(0,0,0,.10));}

.running{
  display:flex;justify-content:space-between;align-items:center;
  font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);
  border-bottom:1px solid var(--line);padding-bottom:9px;margin-bottom:clamp(14px,2.2vw,26px);flex:0 0 auto;
}
.folio{font-family:'Fraunces',serif;font-weight:600;font-size:11px;display:flex;align-items:center;gap:8px;letter-spacing:.04em;color:var(--accent-deep);}
.foot{
  margin-top:auto;padding-top:10px;border-top:1px solid var(--line);
  display:flex;justify-content:space-between;font-size:9.5px;color:var(--muted);
  letter-spacing:.1em;text-transform:uppercase;flex:0 0 auto;
}
.content{flex:1 1 auto;display:flex;flex-direction:column;min-height:0;}

/* editable */
[contenteditable="true"]{outline:none;border-radius:3px;transition:background .15s;}
[contenteditable="true"]:hover{background:var(--paper-soft);}
[contenteditable="true"]:focus{background:#FBF2E9;box-shadow:0 0 0 1px var(--gold);}
[data-ph]:empty:before{content:attr(data-ph);color:var(--muted);opacity:.7;}

/* ===== COVER ===== */
.cover-page .running{border-color:var(--line);}
.cover-top{display:flex;justify-content:space-between;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:clamp(18px,3vw,30px);}
.mast{
  font-family:'Noto Serif KR',serif;font-weight:900;font-size:clamp(30px,4.4vw,50px);
  line-height:1.08;letter-spacing:-.01em;margin:0 0 8px;min-height:1.2em;
}
.cover-dek{font-size:12.5px;color:var(--muted);letter-spacing:.02em;margin-bottom:18px;min-height:1.4em;}
.cover-photo{
  width:100%;flex:1;min-height:150px;border-radius:10px;background-size:cover;background-position:center;
  background-color:var(--paper-soft);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;
  cursor:pointer;margin-bottom:18px;position:relative;
}
.cover-photo .up-hint{font-size:12px;color:var(--muted);text-align:center;padding:0 16px;}
.cover-photo.has-img .up-hint{display:none;}
.cover-photo.has-img{border:none;}
.coverlines{display:flex;flex-direction:column;gap:8px;border-top:1px solid var(--line);padding-top:14px;flex:0 0 auto;}
.coverline{font-size:12.5px;line-height:1.5;display:flex;gap:8px;}
.coverline b{color:var(--accent);font-weight:700;font-family:'Fraunces',serif;flex:0 0 auto;}
.coverline span{flex:1;min-height:1.4em;}

/* ===== CONTENTS ===== */
.kicker{font-family:'Fraunces',serif;font-style:italic;font-weight:500;font-size:13px;color:var(--accent-deep);margin:0 0 4px;}
.headline{font-family:'Noto Serif KR',serif;font-weight:900;font-size:clamp(22px,2.6vw,32px);line-height:1.16;margin:0 0 14px;letter-spacing:-.01em;}
.editor-note p{font-size:12.5px;line-height:1.85;color:#39362F;margin:0 0 4px;min-height:1.8em;}
.divider{height:1px;background:var(--line);margin:18px 0;border:none;}
.toc-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:11px;}
.toc-list li{display:flex;align-items:baseline;gap:10px;font-size:12.5px;}
.toc-num{font-family:'Fraunces',serif;font-weight:600;color:var(--gold);width:20px;flex:0 0 20px;}
.toc-title{font-weight:500;}
.toc-fill{flex:1;border-bottom:1px dotted #C9C6BC;margin:0 6px 3px;}
.toc-page{color:var(--muted);font-family:'Fraunces',serif;}
.chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;}
.chip{font-size:11px;padding:5px 12px;border-radius:20px;background:var(--paper);border:1px solid var(--line);color:var(--ink);position:relative;display:inline-flex;align-items:center;gap:6px;}
.chip-text{min-width:14px;}
.chip .x{width:14px;height:14px;border-radius:50%;background:var(--accent);color:#fff;font-size:9px;line-height:14px;text-align:center;cursor:pointer;display:none;}
.chip:hover .x{display:inline-block;}
.add-chip-btn,.add-btn{font-size:11px;font-weight:500;color:var(--accent-deep);background:none;border:1px dashed var(--accent-deep);border-radius:20px;padding:5px 12px;cursor:pointer;}
.add-chip-btn:hover,.add-btn:hover{background:rgba(215,38,61,.06);}

/* ===== CHARACTER PAGE ===== */
.char-photo{
  width:100%;aspect-ratio:4/3;border-radius:10px;background-size:cover;background-position:center;
  background-color:var(--paper-soft);display:flex;align-items:center;justify-content:center;cursor:pointer;
  margin-bottom:14px;flex:0 0 auto;position:relative;border:1px solid var(--line);
}
.char-photo .up-hint{font-size:11px;color:var(--muted);text-align:center;padding:0 10px;}
.char-photo.has-img .up-hint{display:none;}
.char-photo.has-img{border:none;}
.char-name-row{display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-bottom:2px;}
.char-realname{font-family:'Noto Serif KR',serif;font-weight:900;font-size:clamp(20px,2.2vw,26px);min-width:80px;}
.char-codename{font-family:'Fraunces',serif;font-style:italic;font-size:13px;color:var(--accent-deep);min-width:60px;}
.char-role{font-size:11px;color:var(--muted);margin-bottom:14px;letter-spacing:.02em;min-height:1.4em;}
.info-table{width:100%;border-collapse:collapse;font-size:11.5px;margin-bottom:14px;}
.info-table tr{border-bottom:1px solid var(--line);}
.info-table td{padding:7px 2px;vertical-align:top;}
.info-table td.k{width:64px;color:var(--muted);font-weight:500;letter-spacing:.02em;}
.info-table td.v{font-weight:500;min-height:1.4em;}
.char-desc{font-size:12px;line-height:1.85;color:#39362F;flex:1;min-height:3em;}
.trait3{display:flex;gap:10px;margin-bottom:14px;}
.trait3 span{font-family:'Fraunces',serif;font-weight:600;font-size:13px;padding:5px 3px;border-bottom:2px solid var(--accent);min-width:34px;}

/* ===== TIMELINE ===== */
.tl-col-title{display:flex;align-items:baseline;gap:8px;margin-bottom:10px;}
.tl-tag{font-family:'Fraunces',serif;font-weight:900;font-size:22px;color:var(--gold);min-width:30px;}
.tl-sub{font-size:11px;color:var(--muted);min-width:60px;}
.timeline-track{flex:1;overflow:hidden;display:flex;flex-direction:column;gap:0;position:relative;padding-left:14px;border-left:1px solid var(--line);}
.tl-item{position:relative;padding:0 0 14px 14px;}
.tl-item::before{content:'';position:absolute;left:-19px;top:4px;width:7px;height:7px;border-radius:50%;background:var(--accent);}
.tl-date{font-family:'Fraunces',serif;font-weight:600;font-size:11px;color:var(--accent-deep);margin-bottom:2px;min-height:1.3em;min-width:40px;}
.tl-body{font-size:11.5px;line-height:1.6;color:#39362F;min-height:1.6em;}
.tl-del{float:right;font-size:10px;color:var(--muted);cursor:pointer;opacity:0;transition:.15s;margin-left:6px;}
.tl-item:hover .tl-del{opacity:1;}
.tl-add-wrap{padding-left:14px;margin-top:6px;}

/* ===== LOOK CARDS ===== */
.look-card{display:flex;flex-direction:column;flex:1;min-height:0;}
.look-photo{
  width:100%;flex:1;min-height:150px;border-radius:10px;background-size:cover;background-position:center;
  background-color:var(--paper-soft);display:flex;align-items:center;justify-content:center;cursor:pointer;
  margin-bottom:12px;border:1px solid var(--line);position:relative;
}
.look-photo .up-hint{font-size:11px;color:var(--muted);text-align:center;}
.look-photo.has-img .up-hint{display:none;}
.look-photo.has-img{border:none;}
.look-from{font-size:11px;color:var(--accent-deep);font-weight:700;margin-bottom:4px;letter-spacing:.02em;min-height:1.4em;}
.look-caption{font-size:12px;line-height:1.7;color:#39362F;min-height:2em;}

/* ===== CHEMISTRY ===== */
.chem-row{margin-bottom:14px;}
.chem-label-row{display:flex;justify-content:space-between;font-size:11.5px;margin-bottom:5px;}
.chem-label{font-weight:500;}
.chem-val{font-family:'Fraunces',serif;font-weight:700;color:var(--accent-deep);}
.chem-track{height:6px;background:var(--paper-soft);border-radius:4px;overflow:hidden;position:relative;border:1px solid var(--line);}
.chem-fill{height:100%;background:var(--accent);border-radius:4px;}
.chem-range{width:100%;margin-top:4px;accent-color:var(--accent);height:14px;cursor:pointer;}
.quote-item{border-left:2px solid var(--gold);padding:4px 0 4px 12px;margin-bottom:10px;font-family:'Fraunces',serif;font-style:italic;font-size:12.5px;line-height:1.6;position:relative;}
.quote-text{display:block;min-height:1.6em;}
.quote-who{display:block;font-family:'Noto Sans KR',sans-serif;font-style:normal;font-size:10px;color:var(--muted);margin-top:3px;letter-spacing:.05em;min-height:1.3em;}
.q-del{position:absolute;right:0;top:2px;font-size:10px;color:var(--muted);cursor:pointer;opacity:0;}
.quote-item:hover .q-del{opacity:1;}

.file-hidden{display:none;}

body.exporting .ui-only,
body.exporting .tl-del,
body.exporting .q-del,
body.exporting .chip .x{display:none!important;}
body.exporting [contenteditable="true"]:hover,
body.exporting [contenteditable="true"]:focus{background:transparent;box-shadow:none;}

@media (max-width:860px){
  .spread{flex-direction:column;max-width:480px;}
  .page{aspect-ratio:auto;min-height:640px;}
  .gutter{display:none;}
  .page.left{border-radius:6px 6px 0 0;}
  .page.right{border-radius:0 0 6px 6px;}
}
</style>
</head>
