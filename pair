<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
const spreads = Array.from(document.querySelectorAll('.spread'));
const dotsWrap = document.getElementById('dots');
let current = 0;

spreads.forEach((s,i)=>{
  const d = document.createElement('div');
  d.className = 'dot' + (i===0?' active':'');
  d.addEventListener('click',()=>goTo(i));
  dotsWrap.appendChild(d);
});
const dotEls = Array.from(dotsWrap.children);

function goTo(i){
  if(i<0) i = spreads.length-1;
  if(i>=spreads.length) i = 0;
  spreads[current].classList.remove('active');
  dotEls[current].classList.remove('active');
  current = i;
  spreads[current].classList.add('active');
  dotEls[current].classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}
document.getElementById('prevBtn').addEventListener('click',()=>goTo(current-1));
document.getElementById('nextBtn').addEventListener('click',()=>goTo(current+1));
document.addEventListener('keydown',(e)=>{
  if(document.activeElement && document.activeElement.isContentEditable) return;
  if(e.key==='ArrowRight') goTo(current+1);
  if(e.key==='ArrowLeft') goTo(current-1);
});

const fileInput = document.getElementById('fileInput');
let activeFrame = null;

function bindFrame(el){
  el.addEventListener('click',()=>{
    activeFrame = el;
    fileInput.click();
  });
}
document.querySelectorAll('.char-photo, .look-photo').forEach(bindFrame);
document.getElementById('coverPhoto').addEventListener('click',()=>{
  activeFrame = document.getElementById('coverPhoto');
  fileInput.click();
});

fileInput.addEventListener('change',(e)=>{
  const file = e.target.files[0];
  if(!file || !activeFrame) return;
  const reader = new FileReader();
  reader.onload = (ev)=>{
    activeFrame.style.backgroundImage = `url(${ev.target.result})`;
    activeFrame.classList.add('has-img');
  };
  reader.readAsDataURL(file);
  fileInput.value = '';
});

document.getElementById('addChip').addEventListener('click',()=>{
  const chip = document.createElement('span');
  chip.className = 'chip';
  chip.innerHTML = '<span class="chip-text" contenteditable="true" data-ph="#키워드"></span><span class="x">×</span>';
  document.getElementById('chipBox').appendChild(chip);
  chip.querySelector('.chip-text').focus();
});
document.getElementById('chipBox').addEventListener('click',(e)=>{
  if(e.target.classList.contains('x')){
    e.target.closest('.chip').remove();
  }
});

function makeTlItem(){
  const item = document.createElement('div');
  item.className = 'tl-item';
  item.innerHTML = `<span class="tl-del ui-only">삭제 ×</span><div class="tl-date" contenteditable="true" data-ph="MM/DD"></div><div class="tl-body" contenteditable="true" data-ph="새 사건을 적어보세요."></div>`;
  return item;
}
document.querySelectorAll('[data-add]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const track = document.getElementById(btn.dataset.add);
    const item = makeTlItem();
    track.appendChild(item);
    item.querySelector('.tl-body').focus();
  });
});
document.querySelectorAll('.timeline-track').forEach(track=>{
  track.addEventListener('click',(e)=>{
    if(e.target.classList.contains('tl-del')){
      e.target.closest('.tl-item').remove();
    }
  });
});

function bindChemRow(row){
  const range = row.querySelector('.chem-range');
  const fill = row.querySelector('.chem-fill');
  const val = row.querySelector('.chem-val');
  range.addEventListener('input',()=>{
    fill.style.width = range.value + '%';
    val.textContent = range.value;
  });
}
document.querySelectorAll('.chem-row').forEach(bindChemRow);
document.getElementById('addChem').addEventListener('click',()=>{
  const row = document.createElement('div');
  row.className = 'chem-row';
  row.innerHTML = `<div class="chem-label-row"><span class="chem-label" contenteditable="true">새 지수</span><span class="chem-val">50</span></div>
  <div class="chem-track"><div class="chem-fill" style="width:50%"></div></div>
  <input type="range" class="chem-range ui-only" min="0" max="100" value="50">`;
  document.getElementById('chemBox').appendChild(row);
  bindChemRow(row);
});

document.getElementById('addQuote').addEventListener('click',()=>{
  const item = document.createElement('div');
  item.className = 'quote-item';
  item.innerHTML = `<span class="q-del ui-only">×</span><span class="quote-text" contenteditable="true" data-ph="새 대사를 적어보세요."></span><span class="quote-who" contenteditable="true" data-ph="화자"></span>`;
  document.getElementById('quoteBox').appendChild(item);
  item.querySelector('.quote-text').focus();
});
document.getElementById('quoteBox').addEventListener('click',(e)=>{
  if(e.target.classList.contains('q-del')){
    e.target.closest('.quote-item').remove();
  }
});

document.getElementById('saveBtn').addEventListener('click', async ()=>{
  const target = spreads[current];
  document.body.classList.add('exporting');
  try{
    const canvas = await html2canvas(target, {backgroundColor:'#FFFFFF', scale:2, useCORS:true});
    const link = document.createElement('a');
    const names = ['cover-contents','profiles','timeline','todays-look','chemistry-quotes'];
    link.download = `pair-magazine_${names[current] || current}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
  }catch(err){
    alert('이미지 저장 중 문제가 발생했습니다. 다시 시도해주세요.');
  }finally{
    document.body.classList.remove('exporting');
  }
});
</script>
